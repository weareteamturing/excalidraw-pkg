{
  "compilerOptions": {
    "target": "ESNext",
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "allowSyntheticDefaultImports": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "emitDeclarationOnly": true,
    "outDir": "./dist/types",
    "paths": {
      "@excalidraw/utils": ["./utils/index.ts"],
      "@excalidraw/utils/*": ["./utils/*"]
    }
  },
  "include": ["**/*"],
  "exclude": ["**/*.test.*", "tests", "types", "examples", "dist", "utils"]
}
